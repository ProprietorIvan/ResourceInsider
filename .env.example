NODE_ENV=development
PORT=3001
# Local: http://localhost:5173  |  Vercel: optional — CORS defaults to https://VERCEL_URL if unset
BASE_URL=http://localhost:5173

# MongoDB (use a dedicated database name for this app)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/resourceinsider?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Stripe (test keys for local dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STOCK_PICKS_PRICE_ID=price_...
STRIPE_PRIVATE_PLACEMENTS_PRICE_ID=price_...

# Optional: publishable key if you add Stripe.js client-side later
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# SMTP for password reset (Gmail app password or other)
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# --- Vercel (set in Project → Settings → Environment Variables) ---
# Required: MONGODB_URI, JWT_SECRET, Stripe keys (and SMTP if using password reset)
# BASE_URL: set to https://your-app.vercel.app if preview URLs or custom domain differ from VERCEL_URL
# VERCEL_URL is injected automatically (no https); the app builds CORS origin from it when BASE_URL is empty
